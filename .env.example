# Expo: переменные с префиксом EXPO_PUBLIC_ попадают в клиентский бандл.

# EXPO_PUBLIC_API_URL=https://xn--90abjzbpsjij7e.xn--p1ai

# VK ID — тот же app id, что VK_APP_ID на backend (standalone OAuth для стриминга).
# Для EAS-сборки задайте в https://expo.dev → waaf-streamer → Environment variables
# (профили preview и production), затем пересоберите APK.
# EXPO_PUBLIC_VK_APP_ID=
#
# В кабинете VK ID → Redirect URI (то же приложение, что VK_APP_ID на backend):
# vk<EXPO_PUBLIC_VK_APP_ID>://vk.ru/blank.html
# Пример для id 54569420: vk54569420://vk.ru/blank.html

# RTMP WAAF (заглушка «сайт», v2): полный URL или порт
# EXPO_PUBLIC_RTMP_LIVE_URL=rtmp://localhost:49230/live/
# EXPO_PUBLIC_RTMP_PORT=49230
