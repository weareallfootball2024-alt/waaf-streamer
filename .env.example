# Expo: переменные с префиксом EXPO_PUBLIC_ попадают в клиентский бандл.

# EXPO_PUBLIC_API_URL=https://xn--90abjzbpsjij7e.xn--p1ai

# VK ID — тот же app id, что VK_APP_ID на backend (standalone OAuth)
# EXPO_PUBLIC_VK_APP_ID=

# RTMP WAAF (заглушка «сайт», v2): полный URL или порт
# EXPO_PUBLIC_RTMP_LIVE_URL=rtmp://localhost:49230/live/
# EXPO_PUBLIC_RTMP_PORT=49230
